@baseUrl = http://localhost:3001
@token = Bearer TOKENNI_SHU_YERGA_QOYING
@paymentId = 1
@workerId = 6


### Login - javobdan tokenni yuqoridagi @token ga qo'ying
POST {{baseUrl}}/users/login
Content-Type: application/json

{
  "username": "muhammad",
  "password": "12345678"
}


### To'lovlar ro'yxati
GET {{baseUrl}}/worker-payments?offset=0&limit=20&sort_by=paid_at&sort_order=desc
Authorization: {{token}}


### Worker balans
GET {{baseUrl}}/worker-payments/balance?worker_id={{workerId}}&date_from=2026-06-01&date_to=2026-06-30
Authorization: {{token}}


### Summary - ishchi bo'yicha
GET {{baseUrl}}/worker-payments/summary?group_by=worker&date_from=2026-06-01&date_to=2026-06-30
Authorization: {{token}}


### Summary - to'lov turi bo'yicha
GET {{baseUrl}}/worker-payments/summary?group_by=payment_type&date_from=2026-06-01&date_to=2026-06-30
Authorization: {{token}}


### Bitta to'lov
GET {{baseUrl}}/worker-payments/{{paymentId}}
Authorization: {{token}}


### Oylik/avans berish (super_admin/admin)
POST {{baseUrl}}/worker-payments
Authorization: {{token}}
Content-Type: application/json

{
  "worker_id": {{workerId}},
  "amount": 50000,
  "payment_type": "advance",
  "paid_at": "2026-06-24",
  "period_from": "2026-06-01",
  "period_to": "2026-06-30",
  "note": "Iyun oyi avans"
}


### To'lovni o'zgartirish (super_admin/admin)
PATCH {{baseUrl}}/worker-payments/{{paymentId}}
Authorization: {{token}}
Content-Type: application/json

{
  "amount": 60000,
  "note": "Summa tuzatildi"
}


### To'lovni o'chirish (super_admin/admin)
DELETE {{baseUrl}}/worker-payments/{{paymentId}}
Authorization: {{token}}
